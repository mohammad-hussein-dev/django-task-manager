[run]
source = .
omit =
    */asgi.py
    */wsgi.py
    */manage.py
    */migrations/*
    */__pycache__/*
    */tests/*
    */test_*.py
    */conftest.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
    if 0:
    if False:
