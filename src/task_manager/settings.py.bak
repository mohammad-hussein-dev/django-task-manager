"""
Django settings for task_manager project.

This module configures the bilingual (English/Persian) task management system.
It follows best practices for environment-based configuration, security,
internationalization, and template tag loading.

For more information on this file, see:
    https://docs.djangoproject.com/en/6.0/topics/settings/

For the full list of settings and their values, see:
    https://docs.djangoproject.com/en/6.0/ref/settings/
"""

import os
import sys
from pathlib import Path
from django.utils.translation import gettext_lazy as _


# ============================================================================
# PATH CONFIGURATION
# ============================================================================

# Build paths inside the project like this: BASE_DIR / 'subdir'.
# Since settings.py is located at src/task_manager/settings.py, we need to
# go up three levels to reach the project root (where manage.py and the
# apps/ directory live).
BASE_DIR = Path(__file__).resolve().parent.parent.parent

# Add the 'apps/' directory to Python's module search path.
# This allows us to import local apps as 'accounts' and 'tasks' directly,
# avoiding verbose 'apps.accounts' imports throughout the codebase.
APPS_DIR = BASE_DIR / 'apps'
sys.path.insert(0, str(APPS_DIR))


# ============================================================================
# SECURITY
# ============================================================================

# SECURITY WARNING: keep the secret key used in production secret!
# In production, set DJANGO_SECRET_KEY environment variable to a strong,
# unpredictable value (at least 50 characters, using a cryptographically
# secure random generator). Never hard-code the key in source control.
SECRET_KEY = os.environ.get('DJANGO_SECRET_KEY', 'django-insecure-dev-key')

# SECURITY WARNING: don't run with debug turned on in production!
# Debug mode exposes sensitive error details and enables automatic reloading.
# It is a security risk in production and should always be disabled.
# Use DJANGO_DEBUG=False in production environment.
DEBUG = os.environ.get('DJANGO_DEBUG', 'True').lower() == 'true'

# A list of host/domain names that this Django site can serve.
# In production, set DJANGO_ALLOWED_HOSTS to your domain(s), comma-separated.
# Example: 'example.com,www.example.com,api.example.com'
ALLOWED_HOSTS = os.environ.get('DJANGO_ALLOWED_HOSTS', 'localhost,127.0.0.1').split(',')


# ============================================================================
# APPLICATION DEFINITION
# ============================================================================

# List of installed applications — order matters for template resolution,
# static file discovery, and migration dependencies.
INSTALLED_APPS = [
    # Django core apps
    'django.contrib.admin',         # Admin interface
    'django.contrib.auth',          # Authentication framework
    'django.contrib.contenttypes',  # Required by the permission system
    'django.contrib.sessions',      # Session management
    'django.contrib.messages',      # Message framework
    'django.contrib.staticfiles',   # Static files handling

    # Third-party apps
    'django_extensions',  # Provides useful management commands (shell_plus, etc.)

    # Local apps — imported from APPS_DIR via sys.path modification above
    'accounts',  # User authentication and registration
    'tasks',     # Task CRUD operations
]

# Middleware framework — each component intercepts requests/responses in order.
# The order is significant: middleware is applied top-to-bottom on requests,
# and bottom-to-top on responses.
MIDDLEWARE = [
    'django.middleware.security.SecurityMiddleware',        # Security headers
    'django.contrib.sessions.middleware.SessionMiddleware', # Session handling
    'django.middleware.locale.LocaleMiddleware',           # Language detection
    'django.middleware.common.CommonMiddleware',           # Common functionality
    'django.middleware.csrf.CsrfViewMiddleware',           # CSRF protection
    'django.contrib.auth.middleware.AuthenticationMiddleware', # User binding
    'django.contrib.messages.middleware.MessageMiddleware',  # Message framework
    'django.middleware.clickjacking.XFrameOptionsMiddleware', # Clickjacking protection
]

# Root URL configuration — points to the main urls.py file.
ROOT_URLCONF = 'task_manager.urls'

# Template configuration: where Django looks for HTML templates.
# The 'builtins' option loads template tags globally so that {% translate %}
# and {% static %} work in all templates without requiring {% load %} in each file.
TEMPLATES = [
    {
        'BACKEND': 'django.template.backends.django.DjangoTemplates',
        'DIRS': [BASE_DIR / 'templates'],  # Global template directory
        'APP_DIRS': True,  # Also search within each app's templates/ subdirectory
        'OPTIONS': {
            'context_processors': [
                # Processors that inject variables into the template context
                'django.template.context_processors.debug',
                'django.template.context_processors.request',
                'django.contrib.auth.context_processors.auth',
                'django.contrib.messages.context_processors.messages',
            ],
            # Load i18n and static tags globally — eliminates {% load %} in every template
            'builtins': [
                'django.templatetags.i18n',   # For {% translate %} and {% trans %}
                'django.templatetags.static', # For {% static %}
            ],
        },
    },
]

# WSGI application entry point — used by WSGI servers like Gunicorn or uWSGI.
WSGI_APPLICATION = 'task_manager.wsgi.application'


# ============================================================================
# DATABASE
# ============================================================================

# SQLite for development — lightweight and zero-configuration.
# For production, use PostgreSQL or MySQL for better concurrency,
# reliability, and advanced features (full-text search, JSON fields, etc.).
DATABASES = {
    'default': {
        'ENGINE': 'django.db.backends.sqlite3',
        'NAME': BASE_DIR / 'db.sqlite3',
    }
}


# ============================================================================
# PASSWORD VALIDATION
# ============================================================================

# Password validators enforce security policies during user registration
# and password changes. These prevent common weak password patterns.
AUTH_PASSWORD_VALIDATORS = [
    {
        'NAME': 'django.contrib.auth.password_validation.UserAttributeSimilarityValidator',
        # Prevents passwords that are too similar to user attributes (username, email, etc.)
    },
    {
        'NAME': 'django.contrib.auth.password_validation.MinimumLengthValidator',
        # Enforces a minimum password length (default: 8 characters).
    },
    {
        'NAME': 'django.contrib.auth.password_validation.CommonPasswordValidator',
        # Blocks passwords that are commonly used or appear in known breach lists.
    },
    {
        'NAME': 'django.contrib.auth.password_validation.NumericPasswordValidator',
        # Prevents passwords that are entirely numeric.
    },
]


# ============================================================================
# INTERNATIONALIZATION
# ============================================================================

# Default language for the site — used as a fallback when translation is unavailable.
# This is set to English, but the site supports Persian as well.
LANGUAGE_CODE = 'en-us'

# Time zone for the site. Dates and times are stored in UTC but displayed
# in the user's time zone (Asia/Tehran = Iran Standard Time, UTC+3:30).
TIME_ZONE = 'Asia/Tehran'

# Enable internationalization features: translation, formatting, etc.
USE_I18N = True

# Enable timezone-aware datetime handling — recommended for all projects.
USE_TZ = True

# Supported languages — users can switch between English and Persian.
LANGUAGES = [
    ('en', _('English')),
    ('fa', _('Persian')),
]

# Directory where translation files (.po and .mo) are stored.
# To create translations for a new language, run:
#   django-admin makemessages -l <language_code>
LOCALE_PATHS = [BASE_DIR / 'locale']


# ============================================================================
# STATIC FILES
# ============================================================================

# URL prefix for static files (CSS, JavaScript, images) during development.
# In production, static files are typically served by a CDN or web server.
STATIC_URL = 'static/'

# Additional directories where Django will look for static files,
# beyond each app's static/ subdirectory. This is where global CSS lives.
STATICFILES_DIRS = [BASE_DIR / 'static']


# ============================================================================
# MISCELLANEOUS
# ============================================================================

# Default primary key field type for models.
# BigAutoField (64-bit) is used instead of AutoField (32-bit) to avoid overflow
# issues in applications with many records. Recommended for modern projects.
DEFAULT_AUTO_FIELD = 'django.db.models.BigAutoField'

# Authentication redirect URLs — used by Django's built-in auth views.
# After login, users are redirected to the task list page.
# After logout, users are redirected back to the login page.
LOGIN_REDIRECT_URL = 'tasks:task_list'
LOGOUT_REDIRECT_URL = 'accounts:login'

# The URL name for the login page — used by @login_required and other
# authentication decorators to redirect unauthenticated users.
LOGIN_URL = 'accounts:login'
